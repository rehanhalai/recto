<html xmlns="http://www.w3.org/1999/xhtml">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Welcome to Recto</title>
  </head>
  <body
    style="margin:0; padding:0; font-family:Arial,Helvetica,sans-serif; -webkit-text-size-adjust:100%; -ms-text-size-adjust:100%;"
  >

    <!-- OUTER WRAPPER -->
    <table
      role="presentation"
      border="0"
      cellpadding="0"
      cellspacing="0"
      width="100%"
      style="background-color:#ffffff;"
    >
      <tr>
        <td align="center" style="padding:40px 20px;">

          <!-- CONTAINER -->
          <table
            role="presentation"
            border="0"
            cellpadding="0"
            cellspacing="0"
            width="580"
            style="max-width:580px; width:100%;"
          >

            <!-- HEADER -->
            <tr>
              <td
                align="center"
                style="background-color:#000000; padding:36px 40px 28px; border-radius:4px 4px 0 0;"
              >
                <table
                  role="presentation"
                  border="0"
                  cellpadding="0"
                  cellspacing="0"
                  width="100%"
                >
                  <tr>
                    <td align="center">
                      <img
                        src="cid:rectoLogoLight"
                        alt="Recto"
                        width="180"
                        style="display:block; border:0; margin-bottom:12px;"
                      />
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- GOLD RULE -->
            <tr>
              <td
                style="background-color:#c9a96e; height:3px; font-size:0; line-height:0;"
              >&nbsp;</td>
            </tr>

            <!-- CONTENT -->
            <tr>
              <td
                style="background-color:#faf7f2; border-left:1px solid #ddd8cf; border-right:1px solid #ddd8cf; padding:52px 48px 44px;"
              >

                <!-- Account ready label -->
                <table
                  role="presentation"
                  border="0"
                  cellpadding="0"
                  cellspacing="0"
                  width="100%"
                >
                  <tr>
                    <td>
                      <p
                        style="font-family:Arial,Helvetica,sans-serif; font-size:10px; font-weight:bold; letter-spacing:4px; text-transform:uppercase; color:#c9a96e; margin:0 0 18px 0;"
                      >Your account is ready</p>
                    </td>
                  </tr>
                  <tr>
                    <td>
                      <h1
                        style="font-family:Georgia,'Times New Roman',serif; font-size:28px; font-weight:bold; color:#1c1814; line-height:1.3; margin:0 0 28px 0;"
                      >Welcome to a world of stories and readers.</h1>
                    </td>
                  </tr>
                  <tr>
                    <td>
                      <p
                        style="font-family:Arial,Helvetica,sans-serif; font-size:15px; color:#3d3530; margin:0 0 16px 0;"
                      >Hello
                        <strong
                          style="color:#1c1814;"
                        >{{userName}}</strong>,</p>
                    </td>
                  </tr>
                  <tr>
                    <td>
                      <p
                        style="font-family:Arial,Helvetica,sans-serif; font-size:15px; color:#5a514a; line-height:1.7; margin:0 0 16px 0; font-weight:300;"
                      >We're delighted to have you. Your account has been
                        created and verified — you're now part of a community
                        built around the things that matter most: great books
                        and the people who love them.</p>
                    </td>
                  </tr>
                  <tr>
                    <td>
                      <p
                        style="font-family:Arial,Helvetica,sans-serif; font-size:15px; color:#5a514a; line-height:1.7; margin:0 0 28px 0; font-weight:300;"
                      >Discover shelves, follow readers whose taste you trust,
                        and share the books that have changed you.</p>
                    </td>
                  </tr>

                  <!-- DIVIDER -->
                  <tr>
                    <td style="padding-bottom:28px;">
                      <table
                        role="presentation"
                        border="0"
                        cellpadding="0"
                        cellspacing="0"
                        width="100%"
                      >
                        <tr>
                          <td
                            style="border-top:1px solid #ddd8cf; font-size:0; line-height:0;"
                          >&nbsp;</td>
                        </tr>
                      </table>
                    </td>
                  </tr>

                  <!-- CTA -->
                  <tr>
                    <td style="padding-bottom:28px;">
                      <table
                        role="presentation"
                        border="0"
                        cellpadding="0"
                        cellspacing="0"
                      >
                        <tr>
                          <td style="border-radius:2px;" bgcolor="#1c1814">
                            <a
                              href="{{clientUrl}}"
                              target="_blank"
                              style="display:inline-block; font-family:Arial,Helvetica,sans-serif; font-size:12px; font-weight:bold; color:#f0ebe2; text-decoration:none; letter-spacing:2px; text-transform:uppercase; padding:15px 36px; border:1px solid #1c1814;"
                            >Open Recto</a>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>

                  <!-- NOTE -->
                  <tr>
                    <td>
                      <p
                        style="font-family:Georgia,'Times New Roman',serif; font-size:13px; color:#9a8f85; font-style:italic; margin:0;"
                      >Questions? Simply reply to this email &mdash; we read
                        every one.</p>
                    </td>
                  </tr>
                </table>

              </td>
            </tr>

            <!-- FOOTER ACCENT LINE -->
            <tr>
              <td
                style="background-color:#000000; padding:4px 0 0 0; font-size:0; line-height:0;"
              >
                <table
                  role="presentation"
                  border="0"
                  cellpadding="0"
                  cellspacing="0"
                  width="100%"
                >
                  <tr>
                    <td align="center">
                      <table
                        role="presentation"
                        border="0"
                        cellpadding="0"
                        cellspacing="0"
                      >
                        <tr>
                          <td
                            width="24"
                            style="background-color:#c9a96e; height:1px; font-size:0; line-height:0;"
                          >&nbsp;</td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- FOOTER -->
            <tr>
              <td
                align="center"
                style="background-color:#000000; padding:24px 40px 28px; border-radius:0 0 4px 4px;"
              >
                <p
                  style="font-family:Georgia,'Times New Roman',serif; font-size:13px; font-weight:bold; color:rgba(240,235,226,0.45); letter-spacing:4px; margin:0 0 10px 0;"
                >RECTO</p>
                <p
                  style="font-family:Arial,Helvetica,sans-serif; font-size:11px; color:rgba(240,235,226,0.25); letter-spacing:1px; line-height:1.9; margin:0;"
                >&copy; 2026 Recto. All rights reserved. &nbsp;&middot;&nbsp;
                  Experience the New Way of Reading</p>
              </td>
            </tr>

          </table>
          <!-- END CONTAINER -->

        </td>
      </tr>
    </table>
    <!-- END OUTER WRAPPER -->

  </body>
</html>